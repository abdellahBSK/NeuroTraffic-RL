<?xml version="1.0" encoding="UTF-8"?>
<!--
  NeuroTraffic-RL: Vehicle routes for single intersection
  4 directional flows with turning movements
-->
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- Vehicle type -->
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5.0"
           minGap="2.5" maxSpeed="13.89" guiShape="passenger"/>

    <!-- ===== Routes ===== -->
    <!-- North-South through -->
    <route id="NS" edges="N2C C2S"/>
    <!-- South-North through -->
    <route id="SN" edges="S2C C2N"/>
    <!-- East-West through -->
    <route id="EW" edges="E2C C2W"/>
    <!-- West-East through -->
    <route id="WE" edges="W2C C2E"/>

    <!-- Turning routes -->
    <route id="NE" edges="N2C C2E"/>
    <route id="NW" edges="N2C C2W"/>
    <route id="SE" edges="S2C C2E"/>
    <route id="SW" edges="S2C C2W"/>
    <route id="EN" edges="E2C C2N"/>
    <route id="ES" edges="E2C C2S"/>
    <route id="WN" edges="W2C C2N"/>
    <route id="WS" edges="W2C C2S"/>

    <!-- ===== Vehicle Flows ===== -->
    <!-- Main through-traffic flows (higher volume) -->
    <flow id="flow_NS" type="car" route="NS" begin="0" end="3600"
          vehsPerHour="400" departLane="random" departSpeed="max"/>
    <flow id="flow_SN" type="car" route="SN" begin="0" end="3600"
          vehsPerHour="400" departLane="random" departSpeed="max"/>
    <flow id="flow_EW" type="car" route="EW" begin="0" end="3600"
          vehsPerHour="300" departLane="random" departSpeed="max"/>
    <flow id="flow_WE" type="car" route="WE" begin="0" end="3600"
          vehsPerHour="300" departLane="random" departSpeed="max"/>

    <!-- Turning flows (lower volume) -->
    <flow id="flow_NE" type="car" route="NE" begin="0" end="3600"
          vehsPerHour="100" departLane="random" departSpeed="max"/>
    <flow id="flow_NW" type="car" route="NW" begin="0" end="3600"
          vehsPerHour="50" departLane="random" departSpeed="max"/>
    <flow id="flow_SE" type="car" route="SE" begin="0" end="3600"
          vehsPerHour="50" departLane="random" departSpeed="max"/>
    <flow id="flow_SW" type="car" route="SW" begin="0" end="3600"
          vehsPerHour="100" departLane="random" departSpeed="max"/>
    <flow id="flow_EN" type="car" route="EN" begin="0" end="3600"
          vehsPerHour="50" departLane="random" departSpeed="max"/>
    <flow id="flow_ES" type="car" route="ES" begin="0" end="3600"
          vehsPerHour="50" departLane="random" departSpeed="max"/>
    <flow id="flow_WN" type="car" route="WN" begin="0" end="3600"
          vehsPerHour="50" departLane="random" departSpeed="max"/>
    <flow id="flow_WS" type="car" route="WS" begin="0" end="3600"
          vehsPerHour="50" departLane="random" departSpeed="max"/>

</routes>
