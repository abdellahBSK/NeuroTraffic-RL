# NeuroTraffic-RL Environment Variables
# Copy this file to .env and fill in the values.

# Path to SUMO installation (e.g. /usr/share/sumo or /opt/homebrew/opt/sumo/share/sumo)
SUMO_HOME=/usr/share/sumo

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Directory where trained models are saved
MODELS_DIR=models/

# Directory where logs and TensorBoard data are stored
LOGS_DIR=logs/

# Dashboard metrics file path
METRICS_FILE=logs/metrics.json
